# Supabase (criar projeto em https://supabase.com)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...                      # publica, frontend pode ver
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # SECRETA, só backend

# MercadoPago (criar conta PJ em https://mercadopago.com.br/developers)
MP_ACCESS_TOKEN=TEST-...                      # use TEST- em dev, APP_USR- em prod
MP_WEBHOOK_SECRET=                            # configurado no painel MP

# Server
PORT=3000
NODE_ENV=development

# CORS — origem do frontend (em dev: http://localhost:8765; em prod: https://voltaailha.com.br)
CORS_ORIGIN=http://localhost:8765
