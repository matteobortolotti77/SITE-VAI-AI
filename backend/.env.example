# ============================================================
# Volta à Ilha — Backend environment variables
# Em dev: `npm run dev` (carrega via --env-file=.env, Node 22+)
# Em prod (Railway): setar via dashboard. NÃO setar PORT (Railway injeta).
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...                      # pública (frontend usa)
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # SECRETA — só backend, ignora RLS
SUPABASE_JWT_SECRET=                          # SECRETA — Settings → API → JWT Secret. Valida JWT do admin sem round-trip.

# --- MercadoPago ---
MP_ACCESS_TOKEN=APP_USR-...                   # TEST-... em dev, APP_USR-... em prod
MP_WEBHOOK_SECRET=                            # painel MP → webhooks → signature secret

# --- Resend (email transacional) ---
RESEND_API_KEY=re_...
RESEND_FROM=reservas@voltaailha.com.br        # domínio verificado em resend.com

# --- Z-API (WhatsApp) ---
Z_API_INSTANCE_ID=                            # painel Z-API → instância
Z_API_TOKEN=                                  # painel Z-API → token da instância
Z_API_CLIENT_TOKEN=                           # painel Z-API → segurança → client-token (header obrigatório)
Z_API_WHATSAPP_NUMBER=5575998240043           # número operacional sem '+'

# --- Alertas internos ---
ADMIN_ALERT_WHATSAPPS=+5575998240043          # CSV de números E.164 para alertas (notification worker falhas, refunds, etc)

# --- URLs públicas ---
PUBLIC_BASE_URL=https://api.voltaailha.com.br # base do voucher QR + webhook callbacks

# --- Server ---
PORT=3000                                     # ignorar em Railway (injeta automaticamente)
NODE_ENV=development                          # production em Railway

# --- CORS ---
# Dev local: pode listar múltiplas origins separadas por vírgula
# Prod: APENAS https://voltaailha.com.br
CORS_ORIGIN=http://localhost:8765,http://localhost:8080
